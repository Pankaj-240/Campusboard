<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title>Campusboard</title>
</head>
<body>
    <H1>Campusboard</H1>
    <% for(let e of notices) { %>
        <div class="box">
            <div><strong>Title : </strong><%= e.title %></div>
            <div><strong>Description : </strong><%= e.description.length>100 ? e.description.slice(0,100)+"...": e.description  %>
            </div>
            <div><strong>Author : </strong><%= e.author %></div>
            <div class="imp"> <%=e.important ? "Important" : ""%></div>
            <form action="/notices/<%=e.id%>"> 
            <button><pre> View </pre></button>
            </form>
        </div>
    <% } %>
    <div class="new_notices_btn">
       <a  href="/notices/new">New notices</a> 
    </div>
</body>
</html>