<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit a notice</title>
</head>
<body>
    <a href="/notices">Home</a>
    <form action="/notices/<%=data.id%>?_method=PUT" method="post">
    <div>
        <label for="title">Title : </label>
        <input type="text" name="title" id="title" value="<%= data.title %>" required>
    </div>
    <div>
        <textarea name="description" cols="30" rows="10" required ><%=data.description%></textarea>
    </div>
    <div>
        <label for="author">Author :</label>
        <input type="text" name="author" id="author" value="<%= data.author %>" required>
    </div>
    <button>Submit</button>
    </form>
</body>
</html>